{
  "version": 2,
  "functions": {
    "admin-auth.js": {
      "runtime": "@vercel/node@3.0.7"
    },
    "create-order.js": {
      "runtime": "@vercel/node@3.0.7"
    },
    "save-lead.js": {
      "runtime": "@vercel/node@3.0.7"
    },
    "verify-payment.js": {
      "runtime": "@vercel/node@3.0.7"
    }
  },
  "rewrites": [
    {
      "source": "/api/admin-auth",
      "destination": "/admin-auth"
    },
    {
      "source": "/api/create-order",
      "destination": "/create-order"
    },
    {
      "source": "/api/save-lead",
      "destination": "/save-lead"
    },
    {
      "source": "/api/verify-payment",
      "destination": "/verify-payment"
    },
    {
      "source": "/",
      "destination": "/index.html"
    }
  ]
}
