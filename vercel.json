{
  "version": 2,
  "builds": [
    {
      "src": "api/**/*.js",
      "use": "@vercel/node"
    },
    {
      "src": "site/**/*.html",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api/$1"
    },
    {
      "src": "/",
      "dest": "/site/index.html"
    },
    {
      "src": "/(.*\\.html)",
      "dest": "/site/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/site/$1"
    }
  ]
}
