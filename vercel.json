{
  "version": 2,
  "builds": [
    {
      "src": "api/*.js",
      "use": "@vercel/node"
    },
    {
      "src": "*.html",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    { "src": "/api/admin-auth", "dest": "/api/admin-auth.js" },
    { "src": "/api/create-order", "dest": "/api/create-order.js" },
    { "src": "/api/save-lead", "dest": "/api/save-lead.js" },
    { "src": "/api/verify-payment", "dest": "/api/verify-payment.js" },
    { "src": "/", "dest": "/index.html" },
    { "src": "/(.*)", "dest": "/$1" }
  ]
}
