{
  "version": 2,
  "builds": [
    {
      "src": "admin-auth.js",
      "use": "@vercel/node"
    },
    {
      "src": "create-order.js",
      "use": "@vercel/node"
    },
    {
      "src": "save-lead.js",
      "use": "@vercel/node"
    },
    {
      "src": "verify-payment.js",
      "use": "@vercel/node"
    },
    {
      "src": "*.html",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/admin-auth",
      "dest": "/admin-auth.js"
    },
    {
      "src": "/api/create-order",
      "dest": "/create-order.js"
    },
    {
      "src": "/api/save-lead",
      "dest": "/save-lead.js"
    },
    {
      "src": "/api/verify-payment",
      "dest": "/verify-payment.js"
    },
    {
      "src": "/",
      "dest": "/index.html"
    },
    {
      "src": "/(.*\\.html)",
      "dest": "/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/$1"
    }
  ]
}
